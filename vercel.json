{
  "version": 2,
  "builds": [
    {
      "src": "api/playlist.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/playlist",
      "dest": "api/playlist.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
